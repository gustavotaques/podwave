<!DOCTYPE html>
<html lang="pt-br">

<head>
  <%- include('partials/head', { pageTitle: typeof title !== 'undefined' ? title : 'PodWave — Episódio' }) %>
</head>

<body>
  <%- include('partials/header') %>

  <main class="mx-auto max-w-4xl px-6 py-14 lg:px-0">
    <a href="/episodios/<%= episodio.podcodigo %>"
      class="rise inline-flex items-center gap-2 font-mono text-[11px] uppercase tracking-[0.18em] text-sage transition-colors hover:text-acid">
      ← Voltar para os episódios
    </a>

    <!-- Painel do player -->
    <section class="rise d1 mt-8 overflow-hidden rounded-[2rem] border border-edge bg-panel">
      <div class="border-b border-edge/60 px-8 py-5 sm:px-10">
        <div class="flex flex-wrap items-center justify-between gap-3">
          <span class="flex items-center gap-2 font-mono text-[11px] uppercase tracking-[0.2em] text-acid">
            <span id="onair-light" class="inline-block size-2 rounded-full bg-acid/40"></span>
            <span id="onair-label">Em pausa</span>
          </span>
          <span class="font-mono text-[11px] uppercase tracking-[0.2em] text-sage">
            PodWave • Episódio <%= episodio.epicodigo %>
          </span>
        </div>
      </div>

      <div class="px-8 py-10 sm:px-10">
        <p class="font-mono text-[11px] uppercase tracking-[0.2em] text-sage">
          <%= podnome %>
        </p>
        <h1 class="mt-3 font-display text-3xl font-bold leading-tight tracking-tight sm:text-4xl">
          <%= episodio.epititulo %>
        </h1>
        <% if (episodio.epidescricao) { %>
          <p class="mt-4 max-w-2xl leading-relaxed text-sage">
            <%= episodio.epidescricao %>
          </p>
        <% } %>

        <!-- Player -->
        <audio id="audio-player" preload="metadata" class="hidden">
          <source src="/episodios/<%= episodio.podcodigo %>/<%= episodio.epicodigo %>/audio" type="audio/mpeg" />
          Seu navegador não suporta o elemento de áudio.
        </audio>

        <div class="mt-10 flex items-center gap-6">
          <button type="button" id="play-btn"
            class="flex size-16 shrink-0 items-center justify-center rounded-full bg-acid text-ink transition-transform hover:scale-105"
            aria-label="Reproduzir ou pausar">
            <svg id="icon-play" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"
              class="ml-0.5 size-7">
              <path d="M8 5v14l11-7z" />
            </svg>
            <svg id="icon-pause" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"
              class="hidden size-7">
              <path d="M6 5h4v14H6zM14 5h4v14h-4z" />
            </svg>
          </button>

          <div class="min-w-0 flex-1">
            <input type="range" id="seek" class="seek" value="0" min="0" max="100" step="0.1"
              aria-label="Posição do episódio">
            <div class="mt-2 flex items-center justify-between font-mono text-[11px] tracking-[0.1em] text-sage">
              <span id="time-now">0:00</span>
              <span id="time-total">--:--</span>
            </div>
          </div>

          <span id="player-eq" class="eq paused hidden shrink-0 sm:inline-flex" aria-hidden="true">
            <i></i><i></i><i></i><i></i><i></i>
          </span>
        </div>

        <!-- Ações: favoritar + avaliar -->
        <div class="mt-10 flex flex-wrap items-center justify-between gap-6 border-t border-edge/60 pt-8">
          <form action="/episodios/<%= episodio.podcodigo %>/<%= episodio.epicodigo %>/favoritar" method="POST">
            <button type="submit"
              class="<%= isFavorito ? 'btn-acid' : 'btn-ghost' %> !px-6 !py-2.5 text-sm">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
                fill="<%= isFavorito ? 'currentColor' : 'none' %>" stroke="currentColor" stroke-width="1.5"
                class="size-4">
                <path stroke-linecap="round" stroke-linejoin="round"
                  d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z" />
              </svg>
              <%= isFavorito ? 'Desfavoritar' : 'Favoritar' %>
            </button>
          </form>

          <form id="rating-form" action="/episodios/<%= episodio.podcodigo %>/<%= episodio.epicodigo %>/avaliar"
            method="POST" class="flex items-center gap-3">
            <input type="hidden" name="nota" id="rating-input">
            <div id="star-rating" class="flex items-center gap-1">
              <% for(let i = 1; i <= 5; i++) { %>
                <span data-rating="<%= i %>" class="cursor-pointer transition-transform hover:scale-110">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"
                    class="size-6 <%= i <= (avaliacaoUsuario || 0) ? 'star-on' : 'star-off' %>">
                    <path fill-rule="evenodd"
                      d="M10.788 3.21c.448-1.077 1.976-1.077 2.424 0l2.082 5.007 5.404.433c1.164.093 1.636 1.545.749 2.305l-4.117 3.527 1.257 5.273c.271 1.136-.964 2.033-1.96 1.425L12 18.354 7.373 21.18c-.996.608-2.231-.29-1.96-1.425l1.257-5.273-4.117-3.527c-.887-.76-.415-2.212.749-2.305l5.404-.433 2.082-5.006z"
                      clip-rule="evenodd"></path>
                  </svg>
                </span>
              <% } %>
            </div>
            <span id="rating-feedback" class="font-mono text-[11px] uppercase tracking-[0.14em] text-sage">
              <%= avaliacaoUsuario ? `${avaliacaoUsuario} estrela${avaliacaoUsuario > 1 ? 's' : ''}` : 'Não avaliado' %>
            </span>
          </form>
        </div>
      </div>
    </section>

    <!-- Ficha técnica -->
    <section class="rise d2 mt-6 grid gap-4 sm:grid-cols-3">
      <div class="rounded-3xl border border-edge bg-panel p-6">
        <p class="kicker">Duração</p>
        <p class="mt-2 font-display text-2xl font-semibold">
          <%= episodio.epiduracao_segundos ? `${episodio.epiduracao_segundos}s` : 'N/A' %>
        </p>
      </div>
      <div class="rounded-3xl border border-edge bg-panel p-6">
        <p class="kicker">Publicado em</p>
        <p class="mt-2 font-display text-2xl font-semibold">
          <%= episodio.epidata ? new Date(episodio.epidata).toLocaleDateString('pt-BR') : 'N/A' %>
        </p>
      </div>
      <div class="rounded-3xl border border-edge bg-panel p-6">
        <p class="kicker">Reproduções</p>
        <p class="mt-2 font-display text-2xl font-semibold">
          <%= episodio.epireproducoes %>
        </p>
      </div>
    </section>

    <!-- Progresso -->
    <section class="rise d3 mt-6 rounded-3xl border border-edge bg-panel p-8">
      <div class="flex flex-wrap items-end justify-between gap-6">
        <div>
          <p class="kicker">Progresso de escuta</p>
          <p class="mt-2 text-sage">Você parou em <span class="font-semibold text-cream"><%= progresso %> segundos</span>.</p>
        </div>
        <form action="/episodios/<%= episodio.podcodigo %>/<%= episodio.epicodigo %>/progresso" method="POST"
          class="flex items-center gap-3">
          <input type="number" name="progresso_segundos" value="<%= progresso %>" required
            class="field !w-32 text-center">
          <button type="submit" class="btn-acid !px-6 !py-2.5 text-sm">Atualizar</button>
        </form>
      </div>
    </section>

    <!-- Comentários -->
    <section class="rise d4 mt-14">
      <div class="flex items-baseline justify-between">
        <h2 class="font-display text-2xl font-bold tracking-tight sm:text-3xl">
          Comentários
        </h2>
        <span class="font-mono text-[11px] uppercase tracking-[0.18em] text-sage">
          <%= comentarios.length %> no total
        </span>
      </div>

      <form action="/episodios/<%= episodio.podcodigo %>/<%= episodio.epicodigo %>/comentar" method="POST"
        class="mt-6">
        <label for="comment" class="sr-only">Seu comentário</label>
        <textarea id="comment" name="comentario" rows="4" required class="field resize-y"
          placeholder="Escreva um comentário sobre este episódio..."></textarea>
        <div class="mt-3 flex justify-end">
          <button type="submit" class="btn-acid !px-6 !py-2.5 text-sm">Enviar comentário</button>
        </div>
      </form>

      <div class="mt-8 space-y-4">
        <% if (comentarios && comentarios.length > 0) { %>
          <% comentarios.forEach(comentario => { %>
            <article class="rounded-3xl border border-edge bg-panel p-6">
              <footer class="flex items-center gap-3">
                <span
                  class="flex size-9 shrink-0 items-center justify-center rounded-full bg-acid/10 font-display font-bold text-acid">
                  <%= (comentario.usuarioEmail || '?').charAt(0).toUpperCase() %>
                </span>
                <div class="min-w-0">
                  <p class="truncate text-sm font-semibold">
                    <%= comentario.usuarioEmail %>
                  </p>
                  <time class="font-mono text-[10px] uppercase tracking-[0.14em] text-sage"
                    datetime="<%= comentario.comdata %>"
                    title="<%= new Date(comentario.comdata).toLocaleDateString('pt-BR', { year: 'numeric', month: 'long', day: 'numeric' }) %>">
                    <%= new Date(comentario.comdata).toLocaleDateString('pt-BR', { month: 'short', day: 'numeric', year: 'numeric' }) %>
                  </time>
                </div>
              </footer>
              <p class="mt-4 leading-relaxed text-sage">
                <%= comentario.comtexto %>
              </p>
            </article>
          <% }); %>
        <% } else { %>
          <div class="rounded-3xl border border-dashed border-edge py-14 text-center">
            <p class="font-display text-xl font-semibold text-sage">Ninguém comentou ainda.</p>
            <p class="mt-1 text-sage/70">Seja a primeira pessoa a puxar a conversa.</p>
          </div>
        <% } %>
      </div>
    </section>
  </main>

  <%- include('partials/footer') %>

  <script>
    // ---- Player customizado ----
    const audio = document.getElementById('audio-player');
    const playBtn = document.getElementById('play-btn');
    const iconPlay = document.getElementById('icon-play');
    const iconPause = document.getElementById('icon-pause');
    const seek = document.getElementById('seek');
    const timeNow = document.getElementById('time-now');
    const timeTotal = document.getElementById('time-total');
    const playerEq = document.getElementById('player-eq');
    const onairLight = document.getElementById('onair-light');
    const onairLabel = document.getElementById('onair-label');
    const progressoSalvo = parseInt('<%= progresso || 0 %>', 10) || 0;

    const fmt = (s) => {
      if (!isFinite(s)) return '--:--';
      const m = Math.floor(s / 60);
      const r = Math.floor(s % 60);
      return `${m}:${String(r).padStart(2, '0')}`;
    };

    audio.addEventListener('loadedmetadata', () => {
      seek.max = audio.duration;
      timeTotal.textContent = fmt(audio.duration);
      if (progressoSalvo > 0 && progressoSalvo < audio.duration) {
        audio.currentTime = progressoSalvo;
      }
    });

    audio.addEventListener('timeupdate', () => {
      seek.value = audio.currentTime;
      timeNow.textContent = fmt(audio.currentTime);
      const p = audio.duration ? (audio.currentTime / audio.duration) * 100 : 0;
      seek.style.setProperty('--p', `${p}%`);
    });

    seek.addEventListener('input', () => {
      audio.currentTime = parseFloat(seek.value);
    });

    playBtn.addEventListener('click', () => {
      if (audio.paused) audio.play();
      else audio.pause();
    });

    const setPlaying = (playing) => {
      iconPlay.classList.toggle('hidden', playing);
      iconPause.classList.toggle('hidden', !playing);
      playerEq.classList.toggle('hidden', false);
      playerEq.classList.toggle('paused', !playing);
      onairLabel.textContent = playing ? 'No ar' : 'Em pausa';
      onairLight.classList.toggle('onair-dot', playing);
      onairLight.classList.toggle('bg-acid', playing);
      onairLight.classList.toggle('bg-acid/40', !playing);
    };

    audio.addEventListener('play', () => setPlaying(true));
    audio.addEventListener('pause', () => setPlaying(false));
    audio.addEventListener('ended', () => setPlaying(false));

    // ---- Avaliação com estrelas ----
    const starRating = document.getElementById('star-rating');
    const ratingForm = document.getElementById('rating-form');
    const ratingInput = document.getElementById('rating-input');
    const ratingFeedback = document.getElementById('rating-feedback');
    let currentRating = parseInt('<%= avaliacaoUsuario || 0 %>', 10) || 0;

    starRating.addEventListener('click', (e) => {
      const star = e.target.closest('span[data-rating]');
      if (!star) return;
      const rating = parseInt(star.getAttribute('data-rating'), 10);
      currentRating = rating;

      starRating.querySelectorAll('span[data-rating]').forEach((s) => {
        const value = parseInt(s.getAttribute('data-rating'), 10);
        s.querySelector('svg').classList.toggle('star-on', value <= rating);
        s.querySelector('svg').classList.toggle('star-off', value > rating);
      });

      ratingInput.value = rating;
      ratingFeedback.textContent = `Sua avaliação: ${currentRating} estrela${currentRating > 1 ? 's' : ''}`;
      ratingForm.submit();
    });
  </script>
</body>

</html>
