<!DOCTYPE html>
<html lang="pt-br">

<head>
  <%- include('partials/head', { pageTitle: typeof title !== 'undefined' ? title : 'PodWave — Editar episódio' }) %>
</head>

<body>
  <%- include('partials/header') %>

  <main class="mx-auto max-w-lg px-6 py-16">
    <a href="/meusEpisodios/<%= episodio.podcodigo %>"
      class="rise inline-flex items-center gap-2 font-mono text-[11px] uppercase tracking-[0.18em] text-sage transition-colors hover:text-acid">
      ← Voltar para meus episódios
    </a>

    <div class="rise d1 mt-8 rounded-[2rem] border border-edge bg-panel p-8 sm:p-10">
      <p class="kicker">Ajustes na gravação</p>
      <h1 class="mt-3 font-display text-3xl font-bold tracking-tight">Editar episódio</h1>

      <% if (query.error) { %>
        <div class="mt-6 flex items-center gap-3 rounded-xl border border-red-400/40 bg-red-400/10 px-4 py-3 text-sm text-red-300">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5"
            stroke="currentColor" class="size-5 shrink-0">
            <path stroke-linecap="round" stroke-linejoin="round"
              d="M12 9v3.75m9-.75a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 3.75h.008v.008H12v-.008Z" />
          </svg>
          <%= query.error %>
        </div>
      <% } %>

      <form action="/meusEpisodios/<%= episodio.podcodigo %>/<%= episodio.epicodigo %>" method="POST"
        class="mt-8 space-y-6">
        <input type="hidden" name="podcodigo" value="<%= episodio.podcodigo %>">
        <input type="hidden" name="epicodigo" value="<%= episodio.epicodigo %>">
        <div>
          <label for="epititulo" class="kicker block">Título</label>
          <input type="text" id="epititulo" name="epititulo" value="<%= episodio.epititulo %>" required
            class="field mt-2">
        </div>
        <div>
          <label for="epidescricao" class="kicker block">Descrição</label>
          <textarea id="epidescricao" name="epidescricao" rows="3"
            class="field mt-2 resize-y"><%= episodio.epidescricao %></textarea>
        </div>
        <div>
          <label for="epiurl" class="kicker block">URL da capa</label>
          <input type="text" id="epiurl" name="epiurl" value="<%= episodio.epiurl %>" class="field mt-2">
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label for="epiduracao" class="kicker block">Duração</label>
            <input type="text" id="epiduracao" name="epiduracao" value="<%= episodio.epiduracao %>"
              class="field mt-2">
          </div>
          <div>
            <label for="epidata" class="kicker block">Data</label>
            <input type="date" id="epidata" name="epidata" value="<%= episodio.epidata %>" class="field mt-2">
          </div>
          <div>
            <label for="epinumero" class="kicker block">Número</label>
            <input type="number" id="epinumero" name="epinumero" value="<%= episodio.epinumero %>"
              class="field mt-2">
          </div>
          <div>
            <label for="epireproducoes" class="kicker block">Reproduções</label>
            <input type="number" id="epireproducoes" name="epireproducoes" value="<%= episodio.epireproducoes %>"
              class="field mt-2">
          </div>
        </div>
        <div>
          <label for="epiaudio" class="kicker block">Caminho do áudio</label>
          <input type="text" id="epiaudio" name="epiaudio" value="<%= episodio.epiaudio || '' %>" class="field mt-2"
            placeholder="ex.: audios/episodio1.mp3">
        </div>
        <div class="flex items-center gap-4 pt-2">
          <button type="submit" class="btn-acid flex-1">Salvar</button>
          <a href="/meusEpisodios/<%= episodio.podcodigo %>" class="btn-ghost">Cancelar</a>
        </div>
      </form>
    </div>
  </main>
</body>

</html>
