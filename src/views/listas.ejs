<!DOCTYPE html>
<html lang="pt-br">

<head>
  <%- include('partials/head', { pageTitle: typeof title !== 'undefined' ? title : 'PodWave — Explorar' }) %>
</head>

<body>
  <%- include('partials/header') %>

  <main>
    <!-- Hero -->
    <section class="mx-auto max-w-7xl px-6 pb-10 pt-16 lg:px-10">
      <p class="kicker rise flex items-center gap-2">
        <span class="onair-dot inline-block size-2 rounded-full bg-acid"></span>
        Explorar o catálogo
      </p>
      <h1 class="rise d1 mt-5 font-display text-4xl font-bold leading-tight tracking-tight sm:text-5xl lg:text-6xl">
        Explore os melhores
        <em class="font-light italic text-acid">podcasts.</em>
      </h1>
      <p class="rise d2 mt-4 max-w-xl text-lg text-sage">
        Descubra uma variedade de programas para todos os gostos.
      </p>
    </section>

    <!-- Filtros -->
    <section class="mx-auto flex max-w-7xl flex-wrap gap-3 px-6 pb-12 lg:px-10">
      <a href="/listas" class="chip <%= !query.catcodigo ? 'chip-on' : '' %>">Ver todos</a>
      <% categorias.forEach(categoria => { %>
        <a href="/listas?catcodigo=<%= categoria.catcodigo %>"
          class="chip <%= query.catcodigo == categoria.catcodigo ? 'chip-on' : '' %>">
          <%= categoria.catnome %>
        </a>
      <% }) %>
    </section>

    <!-- Grade de podcasts -->
    <section class="mx-auto grid max-w-7xl grid-cols-1 gap-6 px-6 sm:grid-cols-2 lg:grid-cols-3 lg:px-10">
      <% if (podcasts && podcasts.length > 0) { %>
        <% podcasts.forEach((podcast, idx) => { %>
          <a href="/episodios/<%= podcast.podcodigo %>"
            class="card-lift rise group block overflow-hidden rounded-3xl border border-edge bg-panel"
            style="animation-delay: <%= Math.min(idx, 8) * 0.06 %>s">
            <div class="overflow-hidden">
              <img src="<%= podcast.podurl || '/images/figura02.jpg' %>" alt="Capa de <%= podcast.podnome %>"
                class="h-56 w-full object-cover saturate-[.85] transition-transform duration-500 group-hover:scale-105">
            </div>
            <div class="p-7">
              <p class="font-mono text-[10px] uppercase tracking-[0.2em] text-acid">
                <%= podcast.podcategoria %>
              </p>
              <h3 class="mt-3 font-display text-2xl font-semibold leading-snug">
                <%= podcast.podnome %>
              </h3>
              <p class="mt-2 leading-relaxed text-sage" style="display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;">
                <%= podcast.poddescricao || 'Descrição não disponível' %>
              </p>
              <div class="mt-6 flex items-center justify-between border-t border-edge/60 pt-4">
                <span class="eq paused" aria-hidden="true"><i></i><i></i><i></i><i></i><i></i></span>
                <span class="font-mono text-[11px] uppercase tracking-[0.18em] text-sage transition-colors group-hover:text-acid">
                  Ver episódios →
                </span>
              </div>
            </div>
          </a>
        <% }); %>
      <% } else { %>
        <div class="col-span-full rounded-3xl border border-dashed border-edge py-20 text-center">
          <p class="font-display text-2xl font-semibold text-sage">Silêncio no estúdio...</p>
          <p class="mt-2 text-sage/70">Nenhum podcast encontrado nesta categoria.</p>
        </div>
      <% } %>
    </section>
  </main>

  <%- include('partials/footer') %>

  <script>
    // Liga o equalizador do card no hover
    document.querySelectorAll('.card-lift').forEach((card) => {
      const eq = card.querySelector('.eq');
      if (!eq) return;
      card.addEventListener('mouseenter', () => eq.classList.remove('paused'));
      card.addEventListener('mouseleave', () => eq.classList.add('paused'));
    });
  </script>
</body>

</html>
