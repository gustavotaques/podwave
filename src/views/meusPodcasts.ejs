<!DOCTYPE html>
<html lang="pt-br">

<head>
  <%- include('partials/head', { pageTitle: typeof title !== 'undefined' ? title : 'PodWave — Meus podcasts' }) %>
</head>

<body>
  <%- include('partials/header') %>

  <main class="mx-auto max-w-6xl px-6 py-16 lg:px-10">
    <!-- Cabeçalho da página -->
    <div class="flex flex-wrap items-end justify-between gap-6">
      <div>
        <p class="kicker rise flex items-center gap-2">
          <span class="onair-dot inline-block size-2 rounded-full bg-acid"></span>
          Mesa de controle
        </p>
        <h1 class="rise d1 mt-5 font-display text-4xl font-bold leading-tight tracking-tight sm:text-5xl">
          Meus
          <em class="font-light italic text-acid">podcasts.</em>
        </h1>
      </div>
      <a href="/meusPodcasts/adicionar" class="btn-acid rise d2">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2"
          stroke="currentColor" class="size-4">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
        </svg>
        Novo podcast
      </a>
    </div>

    <% if (query.error) { %>
      <div class="rise mt-8 flex items-center gap-3 rounded-xl border border-red-400/40 bg-red-400/10 px-4 py-3 text-sm text-red-300">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5"
          stroke="currentColor" class="size-5 shrink-0">
          <path stroke-linecap="round" stroke-linejoin="round"
            d="M12 9v3.75m9-.75a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 3.75h.008v.008H12v-.008Z" />
        </svg>
        <%= query.error %>
      </div>
    <% } %>

    <!-- Filtros -->
    <div class="rise d3 mt-10 flex flex-wrap gap-3">
      <a href="/meusPodcasts" class="chip <%= !query.catcodigo ? 'chip-on' : '' %>">Ver todos</a>
      <% categorias.forEach(categoria => { %>
        <a href="/meusPodcasts?catcodigo=<%= categoria.catcodigo %>"
          class="chip <%= query.catcodigo == categoria.catcodigo ? 'chip-on' : '' %>">
          <%= categoria.catnome %>
        </a>
      <% }) %>
    </div>

    <!-- Tabela -->
    <div class="rise d4 mt-8 overflow-hidden rounded-3xl border border-edge">
      <% if (podcasts && podcasts.length > 0) { %>
        <table class="w-full text-left text-sm">
          <thead>
            <tr class="border-b border-edge bg-panel font-mono text-[10px] uppercase tracking-[0.18em] text-sage">
              <th class="px-6 py-4 font-medium">Nome</th>
              <th class="hidden px-6 py-4 font-medium md:table-cell">Descrição</th>
              <th class="hidden px-6 py-4 font-medium sm:table-cell">Categoria</th>
              <th class="px-6 py-4 text-right font-medium">Ações</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-edge/60">
            <% podcasts.forEach(podcast => { %>
              <tr class="transition-colors hover:bg-panel/70">
                <td class="px-6 py-4">
                  <a href="/meusEpisodios/<%= podcast.podcodigo %>"
                    class="font-display text-base font-semibold text-cream transition-colors hover:text-acid">
                    <%= podcast.podnome %>
                  </a>
                </td>
                <td class="hidden max-w-xs truncate px-6 py-4 text-sage md:table-cell">
                  <%= podcast.poddescricao %>
                </td>
                <td class="hidden px-6 py-4 sm:table-cell">
                  <span class="font-mono text-[10px] uppercase tracking-[0.16em] text-acid">
                    <%= podcast.podcategoria %>
                  </span>
                </td>
                <td class="px-6 py-4">
                  <div class="flex items-center justify-end gap-4">
                    <a href="/meusEpisodios/<%= podcast.podcodigo %>"
                      class="font-medium text-sage transition-colors hover:text-cream">Episódios</a>
                    <a href="/meusPodcasts/editar/<%= podcast.podcodigo %>"
                      class="font-medium text-acid transition-colors hover:underline">Editar</a>
                    <form action="meusPodcasts/deletar/<%= podcast.podcodigo %>" method="POST" class="inline">
                      <button type="submit" class="font-medium text-red-400 transition-colors hover:underline"
                        onclick="return confirm('Tem certeza?')">Deletar</button>
                    </form>
                  </div>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      <% } else { %>
        <div class="bg-panel py-20 text-center">
          <p class="font-display text-2xl font-semibold text-sage">Estúdio vazio.</p>
          <p class="mt-2 text-sage/70">Você ainda não tem podcasts nesta categoria.</p>
          <a href="/meusPodcasts/adicionar" class="btn-acid mt-8 !px-6 !py-2.5 text-sm">Criar meu primeiro podcast</a>
        </div>
      <% } %>
    </div>
  </main>

  <%- include('partials/footer') %>
</body>

</html>
