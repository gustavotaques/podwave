<!DOCTYPE html>
<html lang="pt-br">

<head>
  <%- include('partials/head', { pageTitle: typeof title !== 'undefined' ? title : 'PodWave — Episódios' }) %>
</head>

<body>
  <%- include('partials/header') %>

  <main>
    <!-- Hero -->
    <section class="mx-auto max-w-7xl px-6 pb-12 pt-16 lg:px-10">
      <a href="/listas"
        class="rise inline-flex items-center gap-2 font-mono text-[11px] uppercase tracking-[0.18em] text-sage transition-colors hover:text-acid">
        ← Voltar para explorar
      </a>
      <p class="kicker rise d1 mt-8 flex items-center gap-2">
        <span class="onair-dot inline-block size-2 rounded-full bg-acid"></span>
        Episódios do programa
      </p>
      <h1 class="rise d2 mt-5 font-display text-4xl font-bold leading-tight tracking-tight sm:text-5xl lg:text-6xl">
        <%= podnome %>
      </h1>
      <p class="rise d3 mt-4 max-w-xl text-lg text-sage">
        Confira os episódios disponíveis e aperte o play.
      </p>
    </section>

    <!-- Grade de episódios -->
    <section class="mx-auto grid max-w-7xl grid-cols-1 gap-6 px-6 sm:grid-cols-2 lg:grid-cols-3 lg:px-10">
      <% if (episodios && episodios.length > 0) { %>
        <% episodios.forEach((episodio, idx) => { %>
          <a href="/episodios/<%= episodio.podcodigo %>/<%= episodio.epicodigo %>"
            class="card-lift rise group block overflow-hidden rounded-3xl border border-edge bg-panel"
            style="animation-delay: <%= Math.min(idx, 8) * 0.06 %>s">
            <div class="relative overflow-hidden">
              <img src="<%= episodio.epiurl || '/images/figura02.jpg' %>" alt="Capa do episódio"
                class="h-56 w-full object-cover saturate-[.85] transition-transform duration-500 group-hover:scale-105">
              <span
                class="absolute left-4 top-4 rounded-full bg-ink/80 px-3 py-1 font-mono text-[10px] uppercase tracking-[0.18em] text-acid backdrop-blur-sm">
                Ep. <%= episodio.epinumero %>
              </span>
              <span
                class="absolute bottom-4 right-4 flex size-11 items-center justify-center rounded-full bg-acid text-ink opacity-0 transition-all duration-300 group-hover:opacity-100">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="size-4">
                  <path d="M8 5v14l11-7z" />
                </svg>
              </span>
            </div>
            <div class="p-7">
              <h3 class="font-display text-xl font-semibold leading-snug">
                <%= episodio.epititulo %>
              </h3>
              <p class="mt-2 leading-relaxed text-sage" style="display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;">
                <%= episodio.epidescricao || 'Descrição não disponível' %>
              </p>
              <div
                class="mt-6 flex flex-wrap items-center gap-x-5 gap-y-2 border-t border-edge/60 pt-4 font-mono text-[11px] uppercase tracking-[0.14em] text-sage">
                <span><%= episodio.epiduracao || 'N/A' %></span>
                <span><%= episodio.epidata ? new Date(episodio.epidata).toLocaleDateString('pt-BR') : 'N/A' %></span>
                <span class="flex items-center gap-1.5">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="size-3.5 text-acid">
                    <path d="M8 5v14l11-7z" />
                  </svg>
                  <%= episodio.epireproducoes || 0 %>
                </span>
              </div>
            </div>
          </a>
        <% }); %>
      <% } else { %>
        <div class="col-span-full rounded-3xl border border-dashed border-edge py-20 text-center">
          <p class="font-display text-2xl font-semibold text-sage">Silêncio no estúdio...</p>
          <p class="mt-2 text-sage/70">Nenhum episódio encontrado para este podcast.</p>
        </div>
      <% } %>
    </section>
  </main>

  <%- include('partials/footer') %>
</body>

</html>
