# Conexão com o banco — os padrões abaixo já apontam para o container Docker,
# então o .env só é necessário se você quiser sobrescrever algo.
DB_HOST=localhost
DB_PORT=3307
DB_USER=root
DB_PASSWORD=
DB_NAME=podwave

# OBRIGATÓRIO em produção: defina um valor longo e aleatório. O fallback no código
# ('podwave-dev-secret') é público — usá-lo em produção compromete todas as sessões.
SESSION_SECRET=troque-este-segredo
