<!DOCTYPE html>
<html lang="pt-br">

<head>
  <%- include('partials/head', { pageTitle: 'PodWave — Sua próxima obsessão sonora' }) %>
</head>

<body>
  <%- include('partials/header') %>

  <main>
    <!-- Hero -->
    <section class="mx-auto grid max-w-7xl items-center gap-14 px-6 pb-20 pt-16 lg:grid-cols-12 lg:px-10 lg:pt-24">
      <div class="lg:col-span-7">
        <p class="kicker rise flex items-center gap-2">
          <span class="onair-dot inline-block size-2 rounded-full bg-acid"></span>
          No ar — sua próxima obsessão sonora
        </p>
        <h1 class="rise d1 mt-6 font-display text-5xl font-bold leading-[1.02] tracking-tight sm:text-6xl lg:text-7xl">
          Histórias que entram pelo ouvido e
          <em class="font-display font-light italic text-acid">ficam.</em>
        </h1>
        <p class="rise d2 mt-6 max-w-xl text-lg leading-relaxed text-sage">
          O PodWave é a sua plataforma para explorar, ouvir e interagir com podcasts de todos os
          gêneros. Favorite episódios, salve seu progresso e compartilhe opiniões com a comunidade.
        </p>
        <div class="rise d3 mt-10 flex flex-wrap items-center gap-4">
          <a href="/signup" class="btn-acid">
            Comece já
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="size-4">
              <path d="M8 5v14l11-7z" />
            </svg>
          </a>
          <a href="/login" class="btn-ghost">Já tenho conta</a>
        </div>
        <div class="rise d4 mt-12 flex items-center gap-4">
          <span class="eq" aria-hidden="true"><i></i><i></i><i></i><i></i><i></i></span>
          <span class="font-mono text-[11px] uppercase tracking-[0.18em] text-sage">PodWave • transmitindo 24/7</span>
        </div>
      </div>

      <div class="rise d2 relative lg:col-span-5">
        <div class="absolute -inset-3 -rotate-2 rounded-[2rem] border border-acid/40" aria-hidden="true"></div>
        <div class="relative overflow-hidden rounded-[2rem] border border-edge">
          <img src="/images/figura03.jpg" alt="Estúdio de podcast"
            class="aspect-[4/5] w-full object-cover saturate-[.85]">
          <div class="absolute inset-0 bg-gradient-to-t from-ink/90 via-transparent to-transparent" aria-hidden="true">
          </div>
          <div
            class="absolute bottom-5 left-5 right-5 flex items-center gap-4 rounded-2xl border border-edge bg-ink/80 p-4 backdrop-blur-md">
            <span class="flex size-10 shrink-0 items-center justify-center rounded-full bg-acid text-ink">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="size-4">
                <path d="M8 5v14l11-7z" />
              </svg>
            </span>
            <div class="min-w-0">
              <p class="font-mono text-[10px] uppercase tracking-[0.18em] text-acid">Tocando agora</p>
              <p class="truncate text-sm font-medium">O futuro chega pelos fones</p>
            </div>
            <span class="eq ml-auto shrink-0" aria-hidden="true"><i></i><i></i><i></i><i></i><i></i></span>
          </div>
        </div>
      </div>
    </section>

    <!-- Letreiro -->
    <div class="overflow-hidden border-y border-edge/60 py-5" aria-hidden="true">
      <div class="marquee flex w-max whitespace-nowrap font-display text-2xl font-semibold uppercase tracking-wide text-sage/70">
        <% for (let i = 0; i < 2; i++) { %>
          <span class="flex items-center">
            <span class="px-6">Tecnologia</span><span class="text-acid">✦</span>
            <span class="px-6">Negócios</span><span class="text-acid">✦</span>
            <span class="px-6">Esporte</span><span class="text-acid">✦</span>
            <span class="px-6">Cultura</span><span class="text-acid">✦</span>
            <span class="px-6">Humor</span><span class="text-acid">✦</span>
            <span class="px-6">Ciência</span><span class="text-acid">✦</span>
            <span class="px-6">Histórias reais</span><span class="text-acid">✦</span>
          </span>
        <% } %>
      </div>
    </div>

    <!-- Manifesto -->
    <section class="mx-auto grid max-w-7xl gap-10 px-6 py-24 lg:grid-cols-2 lg:px-10">
      <h2 class="font-display text-4xl font-bold leading-tight tracking-tight sm:text-5xl">
        A plataforma ideal para encontrar
        <span class="text-acid">seu podcast favorito.</span>
      </h2>
      <p class="self-center text-lg leading-relaxed text-sage">
        O PodWave oferece uma experiência única para amantes de podcasts: navegue por categorias,
        salve seu progresso de escuta e participe da conversa com comentários e avaliações. Tudo em
        uma interface pensada para quem vive de fones no ouvido.
      </p>
    </section>

    <!-- Funcionalidades -->
    <section class="mx-auto max-w-7xl px-6 pb-24 lg:px-10">
      <p class="kicker">O que você encontra aqui</p>
      <h2 class="mt-4 font-display text-3xl font-bold tracking-tight sm:text-4xl">
        Funcionalidades que facilitam sua rotina
      </h2>
      <div class="mt-12 grid gap-6 md:grid-cols-3">
        <div class="card-lift rounded-3xl border border-edge bg-panel p-8">
          <span class="flex size-12 items-center justify-center rounded-2xl bg-acid/10 text-acid">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5"
              stroke="currentColor" class="size-6">
              <path stroke-linecap="round" stroke-linejoin="round"
                d="M3 8.689c0-.864.933-1.406 1.683-.977l7.108 4.061a1.125 1.125 0 0 1 0 1.954l-7.108 4.061A1.125 1.125 0 0 1 3 16.811V8.69ZM12.75 8.689c0-.864.933-1.406 1.683-.977l7.108 4.061a1.125 1.125 0 0 1 0 1.954l-7.108 4.061a1.125 1.125 0 0 1-1.683-.977V8.69Z" />
            </svg>
          </span>
          <h3 class="mt-6 font-display text-xl font-semibold">Ouça em qualquer lugar</h3>
          <p class="mt-3 leading-relaxed text-sage">
            Streaming de áudio com salvamento de progresso: pause no ônibus, retome no sofá.
          </p>
        </div>
        <div class="card-lift rounded-3xl border border-edge bg-panel p-8">
          <span class="flex size-12 items-center justify-center rounded-2xl bg-acid/10 text-acid">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5"
              stroke="currentColor" class="size-6">
              <path stroke-linecap="round" stroke-linejoin="round"
                d="M12 18.75a6 6 0 0 0 6-6v-1.5m-6 7.5a6 6 0 0 1-6-6v-1.5m6 7.5v3.75m-3.75 0h7.5M12 15.75a3 3 0 0 1-3-3V4.5a3 3 0 1 1 6 0v8.25a3 3 0 0 1-3 3Z" />
            </svg>
          </span>
          <h3 class="mt-6 font-display text-xl font-semibold">Comente e interaja</h3>
          <p class="mt-3 leading-relaxed text-sage">
            Avalie episódios de 1 a 5 estrelas e troque ideias com outros ouvintes nos comentários.
          </p>
        </div>
        <div class="card-lift rounded-3xl border border-edge bg-panel p-8">
          <span class="flex size-12 items-center justify-center rounded-2xl bg-acid/10 text-acid">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5"
              stroke="currentColor" class="size-6">
              <path stroke-linecap="round" stroke-linejoin="round"
                d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z" />
            </svg>
          </span>
          <h3 class="mt-6 font-display text-xl font-semibold">Controle seus favoritos</h3>
          <p class="mt-3 leading-relaxed text-sage">
            Favorite episódios e monte sua biblioteca pessoal para nunca perder o fio da meada.
          </p>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="mx-auto max-w-3xl px-6 pb-24 lg:px-0">
      <p class="kicker text-center">Perguntas e respostas</p>
      <h2 class="mt-4 text-center font-display text-3xl font-bold tracking-tight sm:text-4xl">
        Dúvidas frequentes
      </h2>

      <div class="mt-12 divide-y divide-edge/60 border-y border-edge/60">
        <details class="group py-6" open>
          <summary class="flex items-center justify-between gap-4">
            <h3 class="font-display text-lg font-semibold">Como posso me registrar?</h3>
            <span
              class="flex size-8 shrink-0 items-center justify-center rounded-full border border-edge text-acid transition-transform duration-300 group-open:rotate-45">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2"
                stroke="currentColor" class="size-4">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
              </svg>
            </span>
          </summary>
          <p class="mt-4 leading-relaxed text-sage">
            Clique em "Criar conta" no topo da página e preencha os campos solicitados. Após a
            confirmação, você já poderá acessar sua conta e começar a ouvir.
          </p>
        </details>

        <details class="group py-6">
          <summary class="flex items-center justify-between gap-4">
            <h3 class="font-display text-lg font-semibold">Como posso explorar podcasts?</h3>
            <span
              class="flex size-8 shrink-0 items-center justify-center rounded-full border border-edge text-acid transition-transform duration-300 group-open:rotate-45">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2"
                stroke="currentColor" class="size-4">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
              </svg>
            </span>
          </summary>
          <p class="mt-4 leading-relaxed text-sage">
            Navegue pelas categorias disponíveis na página de exploração e filtre por tema. Cada
            podcast mostra seus episódios com descrição, duração e número de reproduções.
          </p>
        </details>

        <details class="group py-6">
          <summary class="flex items-center justify-between gap-4">
            <h3 class="font-display text-lg font-semibold">Como posso favoritar episódios?</h3>
            <span
              class="flex size-8 shrink-0 items-center justify-center rounded-full border border-edge text-acid transition-transform duration-300 group-open:rotate-45">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2"
                stroke="currentColor" class="size-4">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
              </svg>
            </span>
          </summary>
          <p class="mt-4 leading-relaxed text-sage">
            Na página de cada episódio há um botão de favoritar. Os episódios favoritados ficam
            guardados na sua biblioteca, sempre à mão.
          </p>
        </details>

        <details class="group py-6">
          <summary class="flex items-center justify-between gap-4">
            <h3 class="font-display text-lg font-semibold">Como posso avaliar podcasts?</h3>
            <span
              class="flex size-8 shrink-0 items-center justify-center rounded-full border border-edge text-acid transition-transform duration-300 group-open:rotate-45">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2"
                stroke="currentColor" class="size-4">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
              </svg>
            </span>
          </summary>
          <p class="mt-4 leading-relaxed text-sage">
            Clique nas estrelas na página do episódio para dar sua nota de 1 a 5. Sua avaliação ajuda
            outros ouvintes a descobrir bons conteúdos.
          </p>
        </details>

        <details class="group py-6">
          <summary class="flex items-center justify-between gap-4">
            <h3 class="font-display text-lg font-semibold">Como posso entrar em contato?</h3>
            <span
              class="flex size-8 shrink-0 items-center justify-center rounded-full border border-edge text-acid transition-transform duration-300 group-open:rotate-45">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2"
                stroke="currentColor" class="size-4">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
              </svg>
            </span>
          </summary>
          <p class="mt-4 leading-relaxed text-sage">
            Utilize o formulário da seção de contato. Nossa equipe responde o mais rápido possível
            qualquer dúvida ou sugestão.
          </p>
        </details>
      </div>
    </section>

    <!-- CTA -->
    <section class="mx-auto max-w-7xl px-6 lg:px-10">
      <div class="relative overflow-hidden rounded-[2.5rem] bg-acid px-8 py-16 text-ink sm:px-14">
        <svg class="absolute -right-10 -top-16 h-72 w-72 opacity-10" viewBox="0 0 28 24" fill="none"
          xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path
            d="M0.41 10.3847C1.14777 7.4194 2.85643 4.7861 5.2639 2.90424C7.6714 1.02234 10.6393 0 13.695 0C16.7507 0 19.7186 1.02234 22.1261 2.90424C24.5336 4.7861 26.2422 7.4194 26.98 10.3847H25.78C23.7557 10.3549 21.7729 10.9599 20.11 12.1147C20.014 12.1842 19.9138 12.2477 19.81 12.3047H19.67C19.5662 12.2477 19.466 12.1842 19.37 12.1147C17.6924 10.9866 15.7166 10.3841 13.695 10.3841C11.6734 10.3841 9.6976 10.9866 8.02 12.1147C7.924 12.1842 7.8238 12.2477 7.72 12.3047H7.58C7.4762 12.2477 7.376 12.1842 7.28 12.1147C5.6171 10.9599 3.6343 10.3549 1.61 10.3847H0.41ZM23.62 16.6547C24.236 16.175 24.9995 15.924 25.78 15.9447H27.39V12.7347H25.78C24.4052 12.7181 23.0619 13.146 21.95 13.9547C21.3243 14.416 20.5674 14.6649 19.79 14.6649C19.0126 14.6649 18.2557 14.416 17.63 13.9547C16.4899 13.1611 15.1341 12.7356 13.745 12.7356C12.3559 12.7356 11.0001 13.1611 9.86 13.9547C9.2343 14.416 8.4774 14.6649 7.7 14.6649C6.9226 14.6649 6.1657 14.416 5.54 13.9547C4.4144 13.1356 3.0518 12.7072 1.66 12.7347H0V15.9447H1.61C2.39051 15.924 3.154 16.175 3.77 16.6547C4.908 17.4489 6.2623 17.8747 7.65 17.8747C9.0377 17.8747 10.392 17.4489 11.53 16.6547C12.1468 16.1765 12.9097 15.9257 13.69 15.9447C14.4708 15.9223 15.2348 16.1735 15.85 16.6547C16.9901 17.4484 18.3459 17.8738 19.735 17.8738C21.1241 17.8738 22.4799 17.4484 23.62 16.6547Z"
            fill="currentColor" />
        </svg>
        <div class="relative flex flex-col items-start justify-between gap-8 md:flex-row md:items-center">
          <div>
            <h2 class="font-display text-3xl font-bold tracking-tight sm:text-4xl">
              Descubra o mundo dos podcasts
            </h2>
            <p class="mt-3 text-lg text-ink/70">
              Explore, ouça e compartilhe seus favoritos hoje mesmo!
            </p>
          </div>
          <div class="flex shrink-0 flex-wrap gap-4">
            <a href="/signup"
              class="inline-flex items-center justify-center rounded-full bg-ink px-7 py-3 font-bold text-acid transition-transform hover:-translate-y-0.5">
              Cadastrar-se
            </a>
            <a href="/login"
              class="inline-flex items-center justify-center rounded-full border border-ink/30 px-7 py-3 font-semibold text-ink transition-transform hover:-translate-y-0.5">
              Entrar
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>

  <%- include('partials/footer') %>

  <script>
    // Acordeão: fecha os outros <details> ao abrir um
    document.addEventListener('DOMContentLoaded', () => {
      const detailsElements = document.querySelectorAll('details');
      detailsElements.forEach((detail) => {
        detail.querySelector('summary').addEventListener('click', (e) => {
          e.preventDefault();
          detailsElements.forEach((other) => {
            if (other !== detail) other.removeAttribute('open');
          });
          detail.toggleAttribute('open');
        });
      });
    });
  </script>
</body>

</html>
