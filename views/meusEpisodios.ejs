<!DOCTYPE html>
<html lang="pt-br">

<head>
  <%- include('partials/head', { pageTitle: typeof title !== 'undefined' ? title : 'PodWave — Meus episódios' }) %>
</head>

<body>
  <%- include('partials/header') %>

  <main class="mx-auto max-w-6xl px-6 py-16 lg:px-10">
    <a href="/meusPodcasts"
      class="rise inline-flex items-center gap-2 font-mono text-[11px] uppercase tracking-[0.18em] text-sage transition-colors hover:text-acid">
      ← Voltar para meus podcasts
    </a>

    <div class="mt-8 flex flex-wrap items-end justify-between gap-6">
      <div>
        <p class="kicker rise d1 flex items-center gap-2">
          <span class="onair-dot inline-block size-2 rounded-full bg-acid"></span>
          Mesa de controle
        </p>
        <h1 class="rise d2 mt-5 font-display text-4xl font-bold leading-tight tracking-tight sm:text-5xl">
          Meus
          <em class="font-light italic text-acid">episódios.</em>
        </h1>
      </div>
      <a href="/meusEpisodios/<%= podcodigo %>/adicionar" class="btn-acid rise d3">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2"
          stroke="currentColor" class="size-4">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
        </svg>
        Novo episódio
      </a>
    </div>

    <% if (query.error) { %>
      <div class="rise mt-8 flex items-center gap-3 rounded-xl border border-red-400/40 bg-red-400/10 px-4 py-3 text-sm text-red-300">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5"
          stroke="currentColor" class="size-5 shrink-0">
          <path stroke-linecap="round" stroke-linejoin="round"
            d="M12 9v3.75m9-.75a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 3.75h.008v.008H12v-.008Z" />
        </svg>
        <%= query.error %>
      </div>
    <% } %>

    <div class="rise d4 mt-10 overflow-hidden rounded-3xl border border-edge">
      <% if (episodios && episodios.length > 0) { %>
        <div class="overflow-x-auto">
          <table class="w-full min-w-[900px] text-left text-sm">
            <thead>
              <tr class="border-b border-edge bg-panel font-mono text-[10px] uppercase tracking-[0.18em] text-sage">
                <th class="px-6 py-4 font-medium">#</th>
                <th class="px-6 py-4 font-medium">Título</th>
                <th class="px-6 py-4 font-medium">Descrição</th>
                <th class="px-6 py-4 font-medium">Data</th>
                <th class="px-6 py-4 font-medium">Duração</th>
                <th class="px-6 py-4 font-medium">Plays</th>
                <th class="px-6 py-4 text-right font-medium">Ações</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-edge/60">
              <% episodios.forEach(episodio => { %>
                <tr class="transition-colors hover:bg-panel/70">
                  <td class="px-6 py-4 font-mono text-acid"><%= episodio.epinumero %></td>
                  <td class="px-6 py-4">
                    <a href="/meusEpisodios/<%= podcodigo %>/<%= episodio.epicodigo %>/editar"
                      class="font-display text-base font-semibold text-cream transition-colors hover:text-acid">
                      <%= episodio.epititulo %>
                    </a>
                    <p class="mt-1 max-w-[220px] truncate font-mono text-[10px] text-sage/70">
                      <%= episodio.epiurl %>
                    </p>
                  </td>
                  <td class="max-w-xs truncate px-6 py-4 text-sage"><%= episodio.epidescricao %></td>
                  <td class="whitespace-nowrap px-6 py-4 text-sage"><%= episodio.epidata %></td>
                  <td class="px-6 py-4 text-sage"><%= episodio.epiduracao %></td>
                  <td class="px-6 py-4 text-sage"><%= episodio.epireproducoes %></td>
                  <td class="px-6 py-4">
                    <div class="flex items-center justify-end gap-4">
                      <a href="/meusEpisodios/<%= podcodigo %>/<%= episodio.epicodigo %>/editar"
                        class="font-medium text-acid transition-colors hover:underline">Editar</a>
                      <form action="/meusEpisodios/<%= podcodigo %>/<%= episodio.epicodigo %>/delete" method="POST"
                        class="inline">
                        <button type="submit" class="font-medium text-red-400 transition-colors hover:underline"
                          onclick="return confirm('Tem certeza?')">Deletar</button>
                      </form>
                    </div>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } else { %>
        <div class="bg-panel py-20 text-center">
          <p class="font-display text-2xl font-semibold text-sage">Nenhum episódio gravado.</p>
          <p class="mt-2 text-sage/70">Comece adicionando o primeiro episódio deste podcast.</p>
          <a href="/meusEpisodios/<%= podcodigo %>/adicionar" class="btn-acid mt-8 !px-6 !py-2.5 text-sm">
            Adicionar episódio
          </a>
        </div>
      <% } %>
    </div>
  </main>

  <%- include('partials/footer') %>
</body>

</html>
